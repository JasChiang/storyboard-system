# ==========================================
# API Keys (Required)
# ==========================================

# OpenRouter API Key - https://openrouter.ai/settings/keys
NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fal AI API Key - https://fal.ai/dashboard/keys
NEXT_PUBLIC_FAL_API_KEY=your_fal_api_key_here

# Gemini API Key - https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here


# ==========================================
# Model Configuration (Optional)
# ==========================================

# OpenRouter Model - 分鏡腳本生成
# 可選: anthropic/claude-3.5-sonnet, openai/gpt-4o, google/gemini-pro-1.5 等
# 參考: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Fal AI Image Model - 圖片生成
# 可選: fal-ai/nano-banana-pro, fal-ai/flux-pro/v1.1 等
# 參考: https://fal.ai/models
FAL_IMAGE_MODEL=fal-ai/nano-banana-pro

# Fal AI Video Model - 影片生成 (Kling)
# 預設: fal-ai/kling-video/v2.6/pro/image-to-video
FAL_VIDEO_KLING_MODEL=fal-ai/kling-video/v2.6/pro/image-to-video

# Fal AI Video Model - 影片生成 (Seedance)
# 預設: fal-ai/bytedance/seedance/v1.5/pro/image-to-video
FAL_VIDEO_SEEDANCE_MODEL=fal-ai/bytedance/seedance/v1.5/pro/image-to-video

# Gemini Model - 影片分析
# 推薦: gemini-1.5-flash (較高配額), gemini-1.5-pro (最佳品質但配額較低)
# 可選: gemini-2.0-flash-exp (實驗性，配額限制嚴格)
# 參考: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-1.5-flash

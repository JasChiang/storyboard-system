# ==========================================
# API Keys (Required)
# ==========================================

# OpenRouter API Key - https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Fal AI API Key - https://fal.ai/dashboard/keys
# 注意：Server Proxy 使用 FAL_API_KEY（伺服器端金鑰）
# 前端不保存、不傳送 Fal API key
FAL_API_KEY=

# Fal AI 替代認證方式 (擇一使用)
# 方式 1: 使用 FAL_KEY
# FAL_KEY=
# 方式 2: 使用 Key ID + Secret
# FAL_KEY_ID=
# FAL_KEY_SECRET=

# Gemini API Key - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ==========================================
# App Origin (Optional but recommended)
# ==========================================

# App origin used for headers / asset links when server-side code cannot infer window.location.
# If your app does NOT run on http://localhost:3000, set this to your actual origin.
# Example: http://localhost:3001
APP_ORIGIN=

# Public origin for client-side utilities (e.g. OpenReel asset proxy URL building).
# Usually keep this same as APP_ORIGIN.
NEXT_PUBLIC_APP_ORIGIN=


# ==========================================
# Model Configuration (Optional)
# ==========================================

# OpenRouter Model - 分鏡腳本生成
# 可選: anthropic/claude-4.5-sonnet 等
# 參考: https://openrouter.ai/models
OPENROUTER_MODEL=

# OpenRouter Vision Model - 參考圖片分析
# 可選: anthropic/claude-4.5-sonnet, google/gemini-2.0-flash-001 等
# 參考: https://openrouter.ai/models?supported_parameters=vision
OPENROUTER_VISION_MODEL=

# Fal AI Image Model - 圖片生成
# 預設: openai/gpt-image-2
# 其他可選: fal-ai/bytedance/seedream/v5/lite/text-to-image, fal-ai/nano-banana-pro 等
# 參考: https://fal.ai/models
FAL_IMAGE_MODEL=

# Fal AI Video Models - Seedance 2.0 多版本（JSON，可選）
# 影片生成統一使用 Seedance 2.0（已移除 Kling）。
# 支援的 variant key: v20_i2v / v20_i2v_fast / v20_ref / v20_ref_fast / v20_t2v / v20_t2v_fast
# 範例：{"v20_i2v":"fal-ai/bytedance/seedance-2.0/image-to-video","v20_i2v_fast":"fal-ai/bytedance/seedance-2.0/fast/image-to-video","v20_ref":"fal-ai/bytedance/seedance-2.0/reference-to-video","v20_ref_fast":"fal-ai/bytedance/seedance-2.0/fast/reference-to-video","v20_t2v":"fal-ai/bytedance/seedance-2.0/text-to-video","v20_t2v_fast":"fal-ai/bytedance/seedance-2.0/fast/text-to-video"}
FAL_VIDEO_SEEDANCE_MODELS=

# Fal AI Audio Model - 旁白 (Index TTS 2)
# 預設: fal-ai/index-tts-2/text-to-speech
FAL_TTS_INDEX_MODEL=

# Index TTS 預設聲音參考（audio_url）
# 若前端未傳 audioUrl，會使用此值
FAL_TTS_DEFAULT_AUDIO_URL=

# Fal AI Audio Model - 音樂 (ElevenLabs Music)
# 預設: fal-ai/elevenlabs/music
FAL_MUSIC_ELEVENLABS_MODEL=

# Fal AI Audio Model - 音樂 (MiniMax Music v2)
# 預設: fal-ai/minimax-music/v2
FAL_MUSIC_MINIMAX_MODEL=

# Gemini Model - 影片分析 / 提示詞合成
# 預設: gemini-2.5-flash（可改 gemini-2.5-flash-lite 省額度）
# 參考: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=
